# Copy to .env.local and fill in. For local dev these come from `supabase start`.

# Public (browser-safe) Supabase config — used by the Next.js app clients.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-local-anon-key

# Direct Postgres connection — used by scripts/seed.ts and scripts/verify-anchor.ts
# (superuser, bypasses RLS). This is the Supabase CLI local default.
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
